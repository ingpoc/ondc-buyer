# ============================================================
# SSO/Identity Provider Configuration
# ============================================================
# Identity gateway (API) - for /api/auth/validate
# Local: VITE_IDENTITY_URL=http://127.0.0.1:43101
# Production: VITE_IDENTITY_URL=https://identity-aadhar-gateway.onrender.com
VITE_IDENTITY_URL=http://127.0.0.1:43101

# Identity frontend (Web) - for /login page
# Local: VITE_IDENTITY_WEB_URL=http://127.0.0.1:43100
# Production: VITE_IDENTITY_WEB_URL=https://aadharcha.in
VITE_IDENTITY_WEB_URL=http://127.0.0.1:43100

# ============================================================
# Backend API Configuration
# ============================================================
# Explicit production demo mode. Set to true when public deployments should use
# mock catalog and checkout flows instead of a real commerce backend.
VITE_COMMERCE_DEMO_MODE=false

VITE_API_BASE_URL=http://localhost:3001

# Explicitly disable agent runtime requests in deployments that do not host
# /api/agent/runtime and related control-plane endpoints.
VITE_AGENT_RUNTIME_ENABLED=true

# ============================================================
# ONDC Network Configuration
# ============================================================
# ONDC Staging Environment
VITE_ONDC_REGISTRY_URL=https://staging.registry.ondc.org/subscribe
VITE_ONDC_GATEWAY_URL=https://staging.gateway.proteantech.in

# ONDC Network Configuration (for ONDC protocol)
VITE_ONDC_DOMAIN=ONDC:RET10
VITE_ONDC_COUNTRY=IND
VITE_ONDC_CITY=std:080

# Subscriber Identity (for ONDC network registration)
VITE_ONDC_SUBSCRIBER_ID=ondcbuyer.netlify.app
VITE_ONDC_SUBSCRIBER_URL=https://ondcbuyer.netlify.app
VITE_ONDC_BAP_ID=ondcbuyer.netlify.app
VITE_ONDC_BAP_URI=https://ondcbuyer.netlify.app
